# photo_backend systemd 环境变量示例
# 用法：复制到服务器 /etc/photo_backend.env 并按实际修改

# 1) Go 服务端口（默认 8080）
PORT=8080

# 2) 数据库 DSN（按你服务器 MySQL 账号密码修改）
PHOTO_DB_DSN=root:123456@tcp(127.0.0.1:3306)/photography_db?charset=utf8mb4&parseTime=True&loc=Local

# 3) Gin 运行模式（建议 release）
GIN_MODE=release

# 4) 构图模型（ONNX）
COMPOSITION_MODEL_PATH=/root/photo_backend/models/comp_model.onnx
# Linux 上通常必须显式指定 ORT 动态库路径（用你已验证能加载成功的那条）
ONNXRUNTIME_SHARED_LIBRARY_PATH=/root/onnxruntime-linux-x64-1.24.1/lib/libonnxruntime.so

# 5) VLM（拍摄建议/姿势引导）转发
# 生产形态：填 GPU 推理机内网地址，例如 http://10.0.0.12:8000
# 你们当前联调形态（SSH 反向隧道）：填 http://127.0.0.1:8000
VLM_API_BASE_URL=http://127.0.0.1:8000
VLM_HTTP_TIMEOUT_SECONDS=180
